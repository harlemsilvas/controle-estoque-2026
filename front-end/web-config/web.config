<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    
    <!-- Compressão de resposta -->
    <urlCompression doDynamicCompression="true" doStaticCompression="true" />
    
    <!-- Cache control -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <rewrite>
      <rules>

        <!-- 🔐 HTTP → HTTPS Redirect (permanente) -->
        <rule name="HTTP to HTTPS Redirect" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 🔌 API → Backend Node (localhost:3000) -->
        <rule name="Proxy API to Backend" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:3000/api/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="estoque.local" />
          </serverVariables>
        </rule>

        <!-- 📚 Swagger/Docs → Backend -->
        <rule name="Proxy Swagger to Backend" stopProcessing="true">
          <match url="^(api-docs|swagger)(.*)$" />
          <action type="Rewrite" url="http://localhost:3000/{R:0}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="estoque.local" />
          </serverVariables>
        </rule>

        <!-- 🧭 Rotas SPA que colidem com endpoints do backend -->
        <rule name="SPA Overlapping Client Routes" stopProcessing="true">
          <match url="^(login|produto/(novo|editar/[^/]+|[^/]+)|alertas/historico|estoque/(lancamento|movimentacao|movimentacaohistorico))$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_METHOD}" pattern="^GET$" />
            <add input="{HTTP_ACCEPT}" pattern="text/html" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>

        <!-- 🔐 Rotas com autenticação → Backend -->
        <rule name="Proxy Auth Routes to Backend" stopProcessing="true">
          <match url="^(login|usuarios|auth|recuperar-senha|forcar-senha|totais|alertas|estoque|produto|marca|familia|fornecedor|relatorio)(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:0}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="estoque.local" />
          </serverVariables>
        </rule>

        <!-- 📁 Arquivos estáticos (assets, favicon, robots, etc) -->
        <rule name="Static Files" stopProcessing="true">
          <match url="^(assets|public|favicon|robots|sitemap|\.well-known)/(.*)" />
          <action type="None" />
        </rule>

        <!-- 🎨 SPA Routing: Redireciona 404s para index.html -->
        <rule name="SPA Routes" stopProcessing="true">
          <match url="^(?!api|assets|public|favicon|robots)(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>

      </rules>
    </rewrite>

    <!-- Headers de segurança e proxy -->
    <httpProtocol>
      <customHeaders>
        <!-- Segurança -->
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <!-- Info para backend sobre requisição original -->
        <add name="X-Forwarded-Host" value="estoque.local" />
        <add name="X-Forwarded-Proto" value="https" />
      </customHeaders>
    </httpProtocol>

    <!-- Habilitar MIME types necessários -->
    <mimeMap>
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
    </mimeMap>

  </system.webServer>

  <!-- Configurações IIS Application Pool (recomendado: .NET CLR v4.0, Integrated pipeline) -->
  <system.web>
    <httpRuntime maxRequestLength="104857600" executionTimeout="3600" />
  </system.web>

</configuration>
